{
  "enabled": true,
  "network": {
    "allowNetwork": false,
    "allowLocalBinding": false,
    "allowAllUnixSockets": false,
    "allowUnixSockets": [],
    "allowedDomains": [],
    "deniedDomains": []
  },
  "audit": {
    "enabled": false,
    "includeCommands": false
  },
  "bypass": {
    "commands": []
  },
  "filesystem": {
    "denyRead": ["/Users", "/home"],
    "allowRead": [".", "~/.gitconfig", "~/.config/git/config", "/dev/null"],
    "allowWrite": [".", "/dev/null"],
    "denyWrite": [
      "**/.env",
      "**/.env.*",
      "**/*.pem",
      "**/*.key",
      ".pi/sandbox.json",
      "~/.pi/agent/sandbox.json"
    ]
  }
}
